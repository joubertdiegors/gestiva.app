# Copie este arquivo para .env e preencha com os valores reais
# NUNCA commite o arquivo .env

# Django
DEBUG=True
SECRET_KEY=sua-secret-key-aqui

# Hosts permitidos (vírgula, sem espaços desnecessários). Em produção inclua o domínio real.
# ALLOWED_HOSTS=localhost,127.0.0.1,seuusuario.pythonanywhere.com

# Banco de dados (opcional — deixe vazio para usar SQLite em desenvolvimento)
# DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco

# Ficheiros enviados (URL /media/...)
# Fotos de colaborador e scans da carta são servidos por URLs internas com login — NÃO mapeie
# publicamente /media/workforce/photos/ nem /media/workforce/licenses/ (quem souber o caminho acederia sem sessão).
# Com DEBUG=False: ou mapeia só subpastas não sensíveis, ou SERVE_MEDIA=True só se aceitar esse risco.
# SERVE_MEDIA=True

# ──────────────────────────────────────────────────────────────────────────
# Hardening de produção (apenas com DEBUG=False)
# ──────────────────────────────────────────────────────────────────────────
# Origens permitidas em POST com CSRF (lista separada por vírgula).
# Em produção é OBRIGATÓRIO:
# CSRF_TRUSTED_ORIGINS=https://construart.eu,https://www.construart.eu

# HSTS: começa em 1h. Sobe para 31536000 (1 ano) só depois de validares HTTPS estável.
# SECURE_HSTS_SECONDS=3600

# ──────────────────────────────────────────────────────────────────────────
# django-axes (rate limit de login)
# ──────────────────────────────────────────────────────────────────────────
# AXES_FAILURE_LIMIT=5
# AXES_COOLOFF_TIME=1   # horas

# ──────────────────────────────────────────────────────────────────────────
# Sentry (error tracking — free tier 5k eventos/mês). Vazio = desligado.
# ──────────────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@oXXXX.ingest.sentry.io/XXXX
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=construart@0.1.0
# SENTRY_TRACES_SAMPLE_RATE=0.0

# ──────────────────────────────────────────────────────────────────────────
# Backup (scripts/backup.sh)
# ──────────────────────────────────────────────────────────────────────────
# Diretório onde o pg_dump comprimido é guardado antes do upload off-site.
# BACKUP_DIR=/home/<user>/backups/construart
# Janela de retenção local em dias (script faz prune automaticamente).
# BACKUP_RETENTION_DAYS=14
# Caminho absoluto para a pasta media/. Vazio = não arquiva uploads.
# MEDIA_DIR=/home/<user>/construart/media
